#!/bin/bash

# Скрипт для копирования содержимого файла или вывода команды в буфер обмена.

# 1. Проверяем, установлена ли утилита xclip.
#    Делаем это в самом начале, чтобы не выполнять лишних действий.
if ! command -v xclip &> /dev/null; then
    echo "Ошибка: утилита xclip не найдена. Пожалуйста, установите ее."
    echo "Пример для Debian/Ubuntu: sudo apt install xclip"
    exit 1
fi

# 2. Проверяем, были ли переданы аргументы.
if [ $# -eq 0 ]; then
    echo "Использование:"
    echo "  $0 <имя_файла>              - для копирования содержимого файла"
    echo "  $0 <команда>                - для копирования вывода команды"
    echo ""
    echo "Примеры:"
    echo "  $0 ~/.bashrc"
    echo "  $0 ss -tuln"
    echo "  $0 sudo iptables -L -n"
    exit 1
fi

# 3. Основная логика: определяем, файл это или команда.
#    Если передан один аргумент, и он является существующим файлом,
#    то работаем с ним как с файлом.
if [ $# -eq 1 ] && [ -f "$1" ]; then
    xclip -selection clipboard < "$1"
    echo "✔ Содержимое файла '$1' скопировано в буфер обмена."
else
    # Во всех остальных случаях считаем, что нам передали команду.
    # "$@" позволяет передать все аргументы как единую команду.
    # eval выполняет эту команду.
    output=$(eval "$@")
    if [ -n "$output" ]; then
        echo "$output" | xclip -selection clipboard
        echo "✔ Вывод команды '$*' скопирован в буфер обмена."
    else
        echo "⚠️⚠ Команда '$*' не дала вывода для копирования."
    fi
fi
