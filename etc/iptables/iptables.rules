*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

-A INPUT -p icmp -j ACCEPT

-A INPUT -p udp --sport 67 --dport 68 -j ACCEPT
-A INPUT -i virbr0 -p udp --sport 68 --dport 67 -j ACCEPT

-A INPUT -i tun+ -j ACCEPT

-A INPUT -s 10.0.0.0/8 -j ACCEPT
-A INPUT -s 172.16.0.0/12 -j ACCEPT
-A INPUT -s 192.168.0.0/16 -j ACCEPT
-A INPUT -m limit --limit 5/min -j LOG --log-prefix "INPUT DROP: "

-A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A FORWARD -i lo -j ACCEPT

-A FORWARD -i virbr0 -o enp3s0 -j ACCEPT
-A FORWARD -i enp3s0 -o virbr0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

-A FORWARD -i virbr0 -o tun+ -j ACCEPT
-A FORWARD -i tun+ -o virbr0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

-A FORWARD -m limit --limit 5/min -j LOG --log-prefix "FORWARD DROP: "

COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0] 
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

-A POSTROUTING -s 192.168.122.0/24 -o enp3s0 -j MASQUERADE

-A POSTROUTING -s 192.168.122.0/24 -o tun+ -j MASQUERADE

COMMIT
